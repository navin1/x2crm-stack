# --- MySQL ---
DB_ROOT_PASSWORD=change-me
DB_NAME=x2crm
DB_USER=x2crm_user
DB_PASSWORD=change-me

# --- Domain (leave as localhost for local dev; set to your real domain
# only once you migrate to the cloud and have DNS pointed at it — see
# README "Going live on the cloud") ---
CRM_DOMAIN=http://localhost

# --- X2CRM REST API (Admin > API in the X2CRM UI) ---
# Leave these blank until after you've run the X2CRM web installer and
# created/looked up an admin API key — see SETUP.md step 4.
X2CRM_API_URL=http://x2crm:80/index.php/api2
X2CRM_API_USERNAME=
X2CRM_API_KEY=

# --- MailerLite (Integrations > API in MailerLite) ---
MAILERLITE_API_URL=https://connect.mailerlite.com/api
MAILERLITE_API_KEY=

# --- Multi-email support ---
# Comma-separated X2CRM column names holding email data. The first one
# listed is treated as primary. Default assumes a single `email` column —
# add more if your instance has e.g. an alternateEmail field. See README
# "Multiple emails per contact".
EMAIL_FIELDS=email

# --- Any other custom fields to sync (lead source, tier, etc) ---
# Format: x2crmColumn:destinationFieldName, comma-separated. Destination
# name is used as the MailerLite subscriber custom field name. Omit
# ":destinationFieldName" to reuse the same name. See README "Custom fields".
CUSTOM_FIELD_MAP=

# --- How often the sync engine polls X2CRM for changes (ms) ---
POLL_INTERVAL_MS=60000

# --- Backup / migration target (any S3-compatible storage) ---
BACKUP_S3_BUCKET=s3://your-bucket/x2crm-backups

# Shared secret required (as ?secret=... query param) on integration/server.js's
# public routes: /webhooks/mailerlite, /sync/new-lead, /trigger/mailerlite-email.
# Set this in MailerLite's webhook URL config and in any X2Flow/cron caller
# of the trigger endpoints. Generate one with: openssl rand -hex 24
INTEGRATION_SHARED_SECRET=change-me
