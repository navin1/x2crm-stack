# --- MySQL ---
DB_ROOT_PASSWORD=change-me
DB_NAME=x2crm
DB_USER=x2crm_user
DB_PASSWORD=change-me

# --- Domain (leave as localhost for local dev; set to your real domain
# only once you migrate to the cloud and have DNS pointed at it — see
# README "Going live on the cloud") ---
CRM_DOMAIN=http://localhost

# --- X2CRM REST API (Admin > API in the X2CRM UI) ---
# Leave these blank until after you've run the X2CRM web installer and
# created/looked up an admin API key — see SETUP.md step 4. X2CRM_API_KEY
# is NOT a separately-generated token — it must exactly match that user's
# x2_users.userKey column value (Basic Auth password = userKey, verified
# against the DB directly, not a login password or any other field). A
# migrated database's admin user has its own userKey, different from
# whatever a fresh local install generated — copying an old .env over to a
# freshly migrated deployment silently breaks this (401 "Invalid user
# credentials", confirmed live).
X2CRM_API_URL=http://x2crm:80/index.php/api2
X2CRM_API_USERNAME=
X2CRM_API_KEY=

# Admin > API in the X2CRM UI must also have "Enable API access" checked
# (x2_admin.api2 -> enabled) — a migrated database can carry this switched
# off from the original system, which fails every one of the calls above
# with a 503 "API access has been disabled on this system," not an auth
# error, so it's easy to mistake for the userKey problem above instead.

# --- MailerLite (Integrations > API in MailerLite) ---
MAILERLITE_API_URL=https://connect.mailerlite.com/api
MAILERLITE_API_KEY=

# --- Multi-email support ---
# Comma-separated X2CRM column names holding email data. The first one
# listed is treated as primary. Default assumes a single `email` column —
# add more if your instance has e.g. an alternateEmail field. See README
# "Multiple emails per contact".
EMAIL_FIELDS=email

# --- Any other custom fields to sync (lead source, tier, etc) ---
# Format: x2crmColumn:destinationFieldName, comma-separated. Destination
# name is used as the MailerLite subscriber custom field name. Omit
# ":destinationFieldName" to reuse the same name. See README "Custom fields".
CUSTOM_FIELD_MAP=

# --- How often the sync engine polls X2CRM for changes (ms) ---
POLL_INTERVAL_MS=60000

# --- Backup / migration target (any S3-compatible storage) ---
BACKUP_S3_BUCKET=s3://your-bucket/x2crm-backups

# Shared secret required (as ?secret=... query param) on integration/server.js's
# public routes: /sync/new-lead, /trigger/mailerlite-email (NOT
# /webhooks/mailerlite — see MAILERLITE_WEBHOOK_SECRET below, which
# authenticates that route instead). Set this in any X2Flow/cron caller of
# the trigger endpoints. Generate one with: openssl rand -hex 24
INTEGRATION_SHARED_SECRET=change-me

# MailerLite's own per-webhook signing secret (shown when the webhook is
# created/viewed via their API or dashboard — NOT the same value as
# INTEGRATION_SHARED_SECRET above). Used to verify the `Signature` header
# MailerLite sends on every /webhooks/mailerlite call, which lets that route
# work without a static secret sitting in the webhook's URL at all — a
# URL-embedded secret is exactly what a reverse proxy's error/debug logging
# can end up persisting in plaintext. Required; the route fails closed
# (401) without it.
MAILERLITE_WEBHOOK_SECRET=
